PORT=4000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/attendr
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters
JWT_EXPIRES_IN=7d
FAST2SMS_API_KEY=your_fast2sms_api_key
OTP_EXPIRY_MINUTES=10
SUPPORT_EMAIL=support@attendr.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
ALLOWED_ORIGIN=http://localhost:5173
NODE_ENV=development

# Cloudinary (profile photo storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AES-256-GCM key for GPS coordinate encryption (32-byte hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# WhatsApp Cloud API (Meta Business)
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_cloud_api_permanent_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_TEMPLATE_NAME_DAILY=attendr_daily_digest
WHATSAPP_TEMPLATE_NAME_WEEKLY=attendr_weekly_summary

# Razorpay Billing
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxx
